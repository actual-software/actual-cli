# Required
AUTH_TOKEN=your-secret-token-here
GITHUB_TOKEN=ghp_...

# Authentication (choose ONE):
# Option 1: OAuth token (for Claude Max subscribers)
# Extract from macOS Keychain: security find-generic-password -s "Claude Code-credentials" -a "$(whoami)" -w
# Then parse the JSON to get claudeAiOauth.accessToken
# NOTE: Do NOT set ANTHROPIC_AUTH_TOKEN alongside this — it conflicts.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# Option 2: API key (for API billing)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional
LINEAR_API_KEY=lin_api_...
RUST_LOG=info
