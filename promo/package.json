{
  "name": "actual-promo",
  "version": "0.1.0",
  "description": "Remotion project for building promotional videos for the actual CLI",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render",
    "render:hero": "remotion render HeroClip out/hero-1080p.mp4 --codec h264",
    "render:short": "remotion render ShortClip out/short.mp4 --codec h264",
    "render:loop": "remotion render LoopClip out/loop.webm --codec vp8"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
